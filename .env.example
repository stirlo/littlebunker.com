# ── LittleBunker.com — Harold environment config ──────────────────────────────
# Copy to .env and fill in values. NEVER commit .env to git.

# ── Bluesky ────────────────────────────────────────────────────────────────────
# Handle: no @ prefix, e.g. littlebunker.com or littlebunker.bsky.social
BLUESKY_HANDLE=
# App password from: bsky.social -> Settings -> Privacy and Security -> App Passwords
# Create one named "littlebunker-harold" — NOT your login password
BLUESKY_PASSWORD=

# ── Cloudflare Pages ───────────────────────────────────────────────────────────
# API token: dash.cloudflare.com -> My Profile -> API Tokens -> Create Token
# Permissions needed: Account > Cloudflare Pages: Edit
# Same permission set as TGR token — can reuse or create a new scoped one
CLOUDFLARE_API_TOKEN=
# Account ID: visible in CF dashboard URL or right sidebar on any zone page
CLOUDFLARE_ACCOUNT_ID=
# Must match the CF Pages project name exactly (check Pages dashboard)
CF_PAGES_PROJECT_NAME=littlebunker

# ── Jekyll ─────────────────────────────────────────────────────────────────────
JEKYLL_ENV=production
JEKYLL_SITE_DIR=_site

# ── Repo path on Harold ────────────────────────────────────────────────────────
# Absolute path to the cloned repo on Harold
LB_REPO_PATH=/home/dt/littlebunker.com

# ── Logging ────────────────────────────────────────────────────────────────────
# Options: debug, info, warning, error
LOG_LEVEL=info
