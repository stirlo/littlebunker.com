# ── Secrets & environment ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Dependencies ───────────────────────────────────────────────────────────────
node_modules/
vendor/

# ── Jekyll build output ────────────────────────────────────────────────────────
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# ── Harold / runtime generated data ───────────────────────────────────────────
# RSS feed JSON blobs — regenerated each run, no need to track in git
_data/feeds/
# Bluesky posting tracker — state lives on Harold, not in git
_data/posted_to_bluesky.json
# RSS dedup tracking — Harold-managed state
_data/rss_tracking/

# ── System files ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ── Editor artifacts ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Misc generated ─────────────────────────────────────────────────────────────
data/temp/
